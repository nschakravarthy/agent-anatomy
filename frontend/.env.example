# Base path for backend API calls. Defaults to "/api/v1", which the Vite dev
# server proxies to the backend (see vite.config.js). Set to an absolute URL
# (e.g. http://localhost:8000/api/v1) to bypass the proxy.
VITE_API_BASE=/api/v1

# Where the dev proxy forwards /api requests. Defaults to http://localhost:8000.
VITE_PROXY_TARGET=http://localhost:8000
